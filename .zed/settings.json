{
	"lsp": {
		"oxfmt": {
			"initialization_options": {
				"settings": {
					"configPath": "./.oxfmtrc.json",
					"run": "onSave"
				}
			}
		}
	},
	"languages": {
		"JavaScript": {
			"format_on_save": "on",
			"prettier": { "allowed": false },
			"formatter": [{ "language_server": { "name": "oxfmt" } }]
		},
		"TypeScript": {
			"format_on_save": "on",
			"prettier": { "allowed": false },
			"formatter": [{ "language_server": { "name": "oxfmt" } }]
		},
		"JSON": {
			"format_on_save": "on",
			"prettier": { "allowed": false },
			"formatter": [{ "language_server": { "name": "oxfmt" } }]
		},
		"JSONC": {
			"format_on_save": "on",
			"prettier": { "allowed": false },
			"formatter": [{ "language_server": { "name": "oxfmt" } }]
		},
		"HTML": {
			"format_on_save": "on",
			"prettier": { "allowed": false },
			"formatter": [{ "language_server": { "name": "oxfmt" } }]
		}
	}
}
