{
	"name": "@wiki0/cli",
	"version": "0.0.6",
	"description": "wiki0 command line interface",
	"homepage": "https://github.com/spences10/wiki0/tree/main/packages/cli#readme",
	"license": "MIT",
	"author": "Scott Spence <me@scottspence.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spences10/wiki0.git",
		"directory": "packages/cli"
	},
	"bin": {
		"wiki0": "./dist/index.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build:self": "vp exec tsc -p tsconfig.build.json && chmod +x dist/index.js",
		"check:self": "vp exec tsc --noEmit -p tsconfig.json",
		"test:self": "vitest run"
	},
	"dependencies": {
		"@wiki0/core": "workspace:*",
		"citty": "^0.2.2"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"typescript": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:"
	},
	"engines": {
		"node": ">=24.15.0"
	}
}
