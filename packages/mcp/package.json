{
	"name": "@wiki0/mcp",
	"version": "0.0.1",
	"description": "MCP server for wiki0 local-first Markdown memory",
	"homepage": "https://github.com/spences10/wiki0/tree/main/packages/mcp#readme",
	"license": "MIT",
	"author": "Scott Spence <me@scottspence.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spences10/wiki0.git",
		"directory": "packages/mcp"
	},
	"bin": {
		"wiki0-mcp": "./dist/index.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build:self": "vp exec tsc -p tsconfig.build.json && chmod +x dist/index.js",
		"check:self": "vp exec tsc --noEmit -p tsconfig.json",
		"test:self": "vitest run"
	},
	"dependencies": {
		"@tmcp/adapter-valibot": "^0.1.5",
		"@tmcp/transport-stdio": "^0.4.1",
		"@wiki0/core": "workspace:*",
		"tmcp": "^1.18.1",
		"valibot": "^1.2.0"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"typescript": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:"
	},
	"engines": {
		"node": ">=24.15.0"
	}
}
