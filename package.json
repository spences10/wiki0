{
	"name": "wiki0",
	"version": "0.0.0",
	"description": "Local-first AI memory as a Markdown wiki backed by SQLite search and MCP tools",
	"keywords": [
		"ai-memory",
		"cli",
		"knowledge-base",
		"mcp",
		"second-brain",
		"sqlite",
		"wiki"
	],
	"homepage": "https://github.com/spences10/wiki0#readme",
	"bugs": {
		"url": "https://github.com/spences10/wiki0/issues"
	},
	"license": "MIT",
	"author": "Scott Spence <me@scottspence.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spences10/wiki0.git"
	},
	"type": "module",
	"private": true,
	"scripts": {
		"build": "pnpm --filter \"./packages/*\" run build:self",
		"check": "pnpm --filter \"./packages/*\" run build:self && pnpm --filter \"./packages/*\" run check:self",
		"format": "prettier --write .",
		"test": "pnpm --filter \"./packages/*\" --if-present run test:self"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@types/node": "catalog:",
		"prettier": "^3.7.3",
		"typescript": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:"
	},
	"engines": {
		"node": ">=24.15.0"
	},
	"packageManager": "pnpm@11.3.0"
}
